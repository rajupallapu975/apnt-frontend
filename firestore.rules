rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any authenticated user to read and write to the orders collection
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow any authenticated user to read and write to xerox_orders
    match /xerox_orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Allow any authenticated user to read and write to the notifications collection
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow shop owners to manage their shop profiles and order subcollections
    match /shops/{shopId} {
      allow read, write: if request.auth != null;
      
      match /orders/{orderId} {
        allow read, write: if request.auth != null;
      }
      
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null;
      }
    }

    // Allow users to manage their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
